# LLM provider (at least one required — first available is used in order: Anthropic, OpenAI, Gemini, Ollama)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Oracle Autonomous DB connection (required for shoe store queries)
# Get the TLS connection string from OCI Console > Autonomous Database > DB Connection > TLS tab
ORACLE_USER=shoestore
ORACLE_PASSWORD=
ORACLE_CONNECTION_STRING=(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1521)(host=adb.<region>.oraclecloud.com))(connect_data=(service_name=<dbname>_low.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))
ORACLE_AI_PROFILE=SHOESTORE_AI
