# Default: OCI Generative AI Service with xAI Grok 3 Fast.
# OCI auth is read from ~/.oci/config; fill in your compartment OCID below.
LLM_PROVIDER=oci_genai
LLM_MODEL=xai.grok-3-fast

# OCI Generative AI Service
OCI_COMPARTMENT_ID=
# Optional: set this to a model OCID if your tenancy requires one. If empty,
# the app uses LLM_MODEL, e.g. xai.grok-3-fast.
OCI_MODEL_ID=
OCI_REGION=us-chicago-1
OCI_PROFILE=DEFAULT
OCI_MAX_TOKENS=600

# Optional: OpenAI-compatible provider. To use it, set LLM_PROVIDER=openai
# and provide OPENAI_API_KEY or API_KEY depending on your SDK setup.
API_KEY=
OPENAI_API_KEY=

ORACLE_USER=migration_agent
ORACLE_PASSWORD=migration_agent
ORACLE_DSN=localhost:1521/FREEPDB1

MONGO_URI=mongodb://localhost:27017
MONGO_DB=reviews_demo
MONGO_COLLECTION=products

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional runtime cache for generated chat responses. This file is generated
# locally and is intentionally not committed.
DEMO_CACHE_PATH=.cache/demo_cache.json
