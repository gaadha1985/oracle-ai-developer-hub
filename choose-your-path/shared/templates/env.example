# Copy to `.env` and fill in. The skill generates ORACLE_PWD for you.
# Never commit .env — it's in .gitignore.

# ─── Oracle 26ai Free (local Docker) ────────────────────────────────────────
# Must be ≥12 chars, with ≥1 uppercase, ≥1 lowercase, ≥1 digit. The skill
# generates a compliant value automatically.
ORACLE_PWD=replace_me_with_a_strong_pwd_12chars_minimum
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_USER=SYSTEM

# ─── Inference (pick one path) ──────────────────────────────────────────────

# Path A: Local Ollama (beginner default)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b
# Set this only if you picked a Qwen chat model — works around thinking-mode hangs.
# OLLAMA_NUM_THREAD=1

# Path B: OCI Generative AI (intermediate / advanced)
# OCI_REGION=us-chicago-1                # Grok 4 lives here only; Cohere/Llama in all regions.
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxx
# OCI_GENAI_BASE_URL=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/20231130/actions/openai
# OCI_GENAI_MODEL=grok-4
# OCI_GENAI_EMBED_MODEL=cohere.embed-english-v3.0
# OCI_AUTH=config_file                    # or `instance_principal` on OCI compute
# OCI_API_KEY=                            # ONLY for tenancies that enable bearer-token auth.
                                          # Leave blank to use SigV1 via ~/.oci/config (the default).
                                          # See shared/references/oci-genai-openai.md.

# Path C: Bring-your-own OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://your-endpoint/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=...
